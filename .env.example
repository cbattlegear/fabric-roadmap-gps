# Environment Configuration for Fabric GPS Email Service
# Copy this file to .env and fill in your values

# Azure Communication Services Configuration (Required for email functionality)
# Get this from your Azure Communication Services resource in the Azure portal
AZURE_COMMUNICATION_CONNECTION_STRING=endpoint=https://your-acs-resource.communication.azure.com/;accesskey=your-access-key

# Email sender configuration
# This should be a verified sender email in your Azure Communication Services domain
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=Fabric GPS

# Application base URL (used in email links)
# This should be your public domain where the app is hosted
BASE_URL=https://yourdomain.com

# Database connection (if different from default)
# SQL_SERVER_CONNECTION_STRING=your-connection-string

# Azure Front Door cache purge (used by fetch job when data changes)
# AZURE_FRONTDOOR_SUBSCRIPTION_ID=your-subscription-id
# AZURE_FRONTDOOR_RESOURCE_GROUP=your-resource-group
# AZURE_FRONTDOOR_NAME=your-frontdoor-name

# Canonical hostname for 301 redirects (e.g. apex -> www)
# CANONICAL_HOST=www.fabric-gps.com
# Comma-separated list of hosts that should redirect to CANONICAL_HOST
# REDIRECT_HOSTS=fabric-gps.com

# Logging level (optional)
# LOG_LEVEL=INFO

# Setup Instructions:
# 1. Create an Azure Communication Services resource
# 2. Add an email domain (either Azure managed or custom domain)
# 3. Configure sender authentication for your domain
# 4. Copy the connection string to AZURE_COMMUNICATION_CONNECTION_STRING
# 5. Set FROM_EMAIL to a verified sender address in your domain
